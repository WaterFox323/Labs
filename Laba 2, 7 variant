#include <iostream>
#include <list>
using namespace std;

int main() {
    // Локализируем русский язык
    setlocale(LC_ALL, "rus");
    // Ввод параметров арифметической прогрессии
    int a1, d, n;
    cout << "Введите первый член прогрессии: ";
    cin >> a1;
    cout << "Введите разность прогрессии: ";
    cin >> d;
    cout << "Введите количество членов: ";
    cin >> n;

    // Создаём список и заполняем его прогрессией
    list<int> lst;
    int term = a1;
    for (int i = 0; i < n; ++i) {
        lst.push_back(term);
        term += d;
    }

    // Выводим исходный список
    cout << "Исходный список: ";
    for (int x : lst) {
        cout << x << " ";
    }
    cout << endl;

    // Ввод количества позиций для сдвига
    int K;
    cout << "Введите K (количество позиций для сдвига вправо): ";
    cin >> K;

    // Нормализуем K: если список не пуст, достаточно сдвига на K % размер
    if (lst.size() != 0) { // Можем воспользоваться вариантом с !lst.empty()
        K %= lst.size();   // теперь K < размера списка
    }

    // Циклический сдвиг вправо на K позиций
    if (K > 0) {
        // Находим итератор, указывающий на начало последних K элементов
        auto it = lst.end();
        advance(it, -K);   // перемещаем it на K позиций назад от конца
        // Переносим найденный диапазон в начало списка
        lst.splice(lst.begin(), lst, it, lst.end());
    }

    // Вывод результата
    cout << "После сдвига на " << K << " позиций вправо: ";
    for (int x : lst) {
        cout << x << " ";
    }
    cout << endl;

    system("PAUSE");
    return 0;
}
