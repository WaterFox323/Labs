#include <iostream>  // для ввода/вывода (cout, endl)
#include <map>       // для использования multimap
#include <algorithm> // для copy и sort
using namespace std;

int main()
{
    setlocale(LC_ALL, "rus");
    // Исходный двумерный массив 3(строки)x3(столбца) (строки: 0, 1, 2)
    double massive_nums[3][3]
    {
        {1, 3, 2},
        {5, 7, 2},
        {8, 2, 9}
    };


    // Вывод исходного массива
    cout << "Исходный массив:\n";
    for (int i = 0; i < 3; ++i)          // проход по строкам
    {
        for (int j = 0; j < 3; ++j)      // проход по столбцам
        {
            cout << massive_nums[i][j] << " ";
        }
        cout << endl;                    // переход на новую строку после каждой строки массива
    }
    cout << endl;


    // Мультикарта: ключ — медиана строки (double), значение — индекс строки (int)
    // Позволяет хранить несколько записей с одинаковым ключом
    multimap<double, int> medianToIndex;


    // Цикл по всем строкам массива (индексы i = 0, 1, 2)
    for (int i = 0; i < 3; i += 1)
    {

        // Создаём временный одномерный массив для копии текущей строки
        double massive_copy_nums[3];


        // Копируем элементы строки i из massive_nums в massive_copy_nums
        // begin(massive_nums[i]) и end(massive_nums[i]) задают диапазон исходной строки
        // massive_copy_nums — указатель на начало приёмника
        copy(begin(massive_nums[i]), end(massive_nums[i]), massive_copy_nums);


        // Сортируем копию строки по возрастанию (используем указатели на начало и конец массива)
        // После сортировки элементы будут расположены: [наименьший, средний, наибольший]
        sort(massive_copy_nums, massive_copy_nums + 3);


        // Медиана для нечётного количества элементов (3) — это средний элемент (индекс 1)
        double median = massive_copy_nums[1];


        // Вставляем в multimap пару (медиана, индекс строки)
        // Ключ (медиана) автоматически упорядочивается, а строки с разными медианами будут отсортированы по возрастанию медианы
        medianToIndex.insert({ median, i });
    }


    // Выводим результат на экран
    cout << "Результат (медиана строки):\n";


    // Проходим по всем элементам multimap (они уже отсортированы по ключу)
    for (const auto& pair : medianToIndex)
    {
        // pair.first — медиана (ключ), pair.second — индекс строки (значение)
        cout << "Строка " << pair.second << " имеет медиану " << pair.first << endl;
    }


    system("PAUSE");
    return 0;

}
